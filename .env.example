# ============================================================
# Leasing Social — variables d'environnement
# Copier ce fichier en .env et remplir avec les vraies valeurs.
# .env est gitignored, ne JAMAIS le commiter.
# ============================================================

# --- Environnement ---
ENV=dev                       # dev | staging | prod
LOG_LEVEL=INFO

# --- Mode mail global (TEST / PROD) ---
# - test : TOUS les mails (vendeur, concession, comptable) sont redirigés vers MAIL_RECIPIENT_OVERRIDE
# - prod : routage normal (vendeur + concession + comptable HESS)
MAIL_MODE=test
MAIL_RECIPIENT_OVERRIDE=tiffanydellmann@hessautomobile.com

# Comptable HESS (un seul destinataire interne en MAIL_MODE=prod)
MAIL_COMPTABLE=axelsaphir@hessautomobile.com

# SMTP Gmail (compte copilote@hessautomobile.com) — envoi des mails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=copilote@hessautomobile.com
SMTP_PASSWORD=
SMTP_FROM=copilote@hessautomobile.com
SMTP_FROM_NAME=HESS Conformité Leasing

# --- Auth API (token partagé avec n8n et dashboard Streamlit) ---
API_TOKEN=changeme

# --- Auth Dashboard (Google OAuth + whitelist) ---
# Liste CSV des emails autorisés à se connecter au dashboard. Tout email hors liste = refusé.
DASHBOARD_ALLOWED_EMAILS=axelsaphir@hessautomobile.com,tiffanydellmann@hessautomobile.com

# Google OAuth — à configurer en Phase 5b
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8501/oauth2callback

# --- Supabase ---
SUPABASE_URL=
SUPABASE_KEY=                 # service_role pour les écritures backend

# --- IA ---
GEMINI_API_KEY=
OPENAI_API_KEY=

# --- Sentry ---
SENTRY_DSN=

# --- Salesforce (OAuth Username-Password) ---
# Utilisé par Phase 1 (extract_won_dossiers.py) et potentiellement par l'API
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_TOKEN=             # security token (concatené avec password)
SALESFORCE_DOMAIN=login       # 'login' pour prod, 'test' pour sandbox

# --- Phase 1 : chiffrement des PDFs téléchargés en local (RGPD) ---
# Générer avec :  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATASET_ENCRYPTION_KEY=
